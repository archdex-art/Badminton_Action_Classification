# Copy to .env.local and fill in. Never commit real secrets.

# Public canonical site URL (metadata, sitemap, robots).
NEXT_PUBLIC_SITE_URL=https://skeletoncourt.research

# --- Email (verification) ---------------------------------------------------
# If SMTP_HOST + SMTP_PORT are set, verification codes are emailed for real.
# Otherwise a dev transport logs the code to the server console / data/outbox.log
# and the verify screen shows it, so the flow is testable without a mail server.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="SkeletonCourt <no-reply@skeletoncourt.dev>"

# --- Model server (optional) ------------------------------------------------
# Real inference: forward extracted keypoints to the Python FastAPI service
# (POST {MODEL_SERVER_URL}/v1/predict/keypoints). Without it, predictions are
# simulated but still persisted to the database.
MODEL_SERVER_URL=
MODEL_API_KEY=

# The SQLite database lives at ./data/app.db (created automatically, gitignored).
